<UserControl x:Class="WpfApp1.ModifyEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        
        Width="785" Height="550"
        
        Background="Transparent"
        
        >

    <Border CornerRadius="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E5E0F8" Offset="0.0"/>
                <GradientStop Color="#B49DF0" Offset="0.5"/>
                <!-- light purple -->
                <GradientStop Color="#623ED0" Offset="1.0"/>
                <!-- base color -->
            </LinearGradientBrush>
        </Border.Background>
        <Border CornerRadius="10"
     BorderThickness="1">

            <Border.BorderBrush>
                <SolidColorBrush Color="#CCCCCC"/>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"/>

                <Grid Grid.Row="1" Margin="5">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Heading -->
                        <TextBlock Grid.Row="0" Text="Edit Employee Details"
                   FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>

                        <!-- Search ID -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 35">
                            <TextBlock Text="Employee ID:" VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBox x:Name="EmployeeIdTextBox" Width="200" Style="{StaticResource RoundTextBox}" Tag="Enter employee Id"/>
                            <Button Content="Search" Width="80" Margin="10 0 0 0" Click="SearchButton_Click"/>
                        </StackPanel>

                        <!-- Input Fields in Two Columns -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column 1 -->
                            <StackPanel Grid.Column="0" Margin="15 0 20 0">
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="FirstNameTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="First Name"/>
                                    <Button x:Name="FirstNameEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="AddressTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Address"/>
                                    <Button x:Name="AddressEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="PhoneTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Phone Number"/>
                                    <Button x:Name="PhoneEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <ComboBox x:Name="PositionComboBox" Width="320"
                                              Style="{StaticResource StandardComboBox}"
                                              IsEnabled="False"
                                              SelectedIndex="0"
                                              Margin="0">
                                        <ComboBoxItem Content="Select Position" IsEnabled="False" />
                                        <ComboBoxItem Content="Manager"/>
                                        <ComboBoxItem Content="Admin"/>
                                        <ComboBoxItem Content="Developer"/>
                                        <ComboBoxItem Content="Designer"/>
                                        <ComboBoxItem Content="Consultant"/>
                                        <ComboBoxItem Content="Intern"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="EmailTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Email"/>
                                    <Button x:Name="EmailEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 2 -->
                            <StackPanel Grid.Column="1" Margin="30,0,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="LastNameTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Last Name"/>
                                    <Button x:Name="LastNameEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="BirthdayTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Birthday"/>
                                    <Button x:Name="BirthdayEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="BasicSalaryTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Basic Salary"/>
                                    <Button x:Name="SalaryEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <ComboBox x:Name="DepartmentComboBox" Width="320"
                                              Style="{StaticResource StandardComboBox}"
                                              SelectedIndex="0"
                                              IsEnabled="False"
                                              Margin="0">
                                        <ComboBoxItem Content="Select Department" IsEnabled="False" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,25">
                                    <TextBox x:Name="PasswordTextBox" Width="250" Style="{StaticResource RoundTextBox}" Tag="Password"/>
                                    <Button x:Name="PasswordEditButton" Content="Edit" Width="60" Margin="10 0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Update Button -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
                            <Button x:Name="UpdateButton" Content="Update" Width="100" Height="35" Click="UpdateButton_Click" Background="#4C2BB0" BorderBrush="black" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>

</UserControl>
