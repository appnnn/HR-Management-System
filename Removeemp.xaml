<UserControl x:Class="WpfApp1.Removeemp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        
        Width="785" Height="550"
        
        Background="Transparent"
       >

    <Border CornerRadius="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EEF7FF" Offset="0.0"/>
                <GradientStop Color="#CDE8E5" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border CornerRadius="10"
BorderThickness="1">

            <Border.BorderBrush>
                <SolidColorBrush Color="#CCCCCC"/>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1" Margin="5">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Remove an employee" FontSize="22" FontWeight="Bold"
                                    HorizontalAlignment="Left" Margin="0,10,0,20"/>

                        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15" HorizontalAlignment="Center">
                            <TextBox x:Name="EmployeeIdTextBox" Width="300" Margin="0,0,10,0" 
                                    Tag="Enter Employee ID" Style="{StaticResource WatermarkedTextBox}"/>
                            <Button Content="Check" Width="80" Height="50" Click="CheckButton_Click" Style="{StaticResource DeBtn}"  Background="#4C2BB0" BorderBrush="black"/>
                        </StackPanel>

                        <Border Grid.Row="2" Margin="0,0,0,15" Background="White" CornerRadius="10" Padding="15" BorderBrush="#7D7D7D" BorderThickness="1">
                            <StackPanel x:Name="EmployeeDetailsPanel">
                                <!-- Labels filled dynamically -->
                            </StackPanel>
                        </Border>


                        <Button x:Name="RemoveButton" Content="Remove" Grid.Row="3" Width="100"   Background="#4C2BB0" BorderBrush="black"
                                HorizontalAlignment="Center" Click="RemoveButton_Click" 
                                IsEnabled="False"
                                Style="{StaticResource DeBtn}"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>
