<Window x:Class="WpfApp1.AddByAdmin"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="SignupWindow"
        Width="485" Height="550"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="10">
        <Border.Background>
            <SolidColorBrush Color="#F0F2F5"/>
        </Border.Background>
        <Border CornerRadius="10"
            BorderThickness="1">

            <Border.BorderBrush>
                <SolidColorBrush Color="#CCCCCC"/>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnClose"
                                Grid.Column="3"
                                Style="{StaticResource CloseBtn}"
                                Click="btnClose_Click">
                            <Button.Content>
                                <Image Source="/Images/close.png" Height="15" Width="30"/>
                            </Button.Content>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="10">




                    <Grid Grid.Column="1" Margin="65,0,35,5">
                        <Grid Margin="0,-10,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Register" 
                                       Grid.Row="0"
                                       FontSize="30" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,12,0,10"/>
                            <Grid x:Name="RegistrationContainer" Grid.Row="1" Margin="0,20,0,0">
                                <Grid x:Name="RegistrationStepOne" Visibility="Visible" Margin="-9,0,9,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0"
                                             x:Name="FirstNameStep1"
                                             Style="{StaticResource WatermarkedTextBox}" Tag="First Name"/>
                                    <TextBox Grid.Row="1"
                                             x:Name="LastNameStep1"
                                        Style="{StaticResource WatermarkedTextBox}" Tag="Last Name"/>
                                    <TextBox Grid.Row="2"
                                             x:Name="AddressStep1"
                                    Style="{StaticResource WatermarkedTextBox}" Tag="Address"/>
                                    <TextBox Grid.Row="3"
                                             x:Name="BirthdayStep1"
                                      Style="{StaticResource WatermarkedTextBox}" Tag="Birthday"/>
                                    <ComboBox Grid.Row="4"
                                              x:Name="GenderStep1"
                                          Panel.ZIndex="10"
                                          SelectionChanged="ComboBox_SelectionChanged"
                                          Style="{StaticResource StandardComboBox}"
                                          Margin="0,4,0,47" Grid.RowSpan="2"  SelectedIndex="0">
                                        <ComboBoxItem Content="Select the Gender" IsEnabled="False"/>
                                        <ComboBoxItem Content="Male" />
                                        <ComboBoxItem Content="Female"/>
                                    </ComboBox>
                                    <TextBox Grid.Row="5"
                                             x:Name="PhoneStep1"
                                             Style="{StaticResource WatermarkedTextBox}" Tag="Phone Number"
                                             Margin="0,51,0,0"/>

                                    <Button Content="Next" 
                                            HorizontalAlignment="Center" 
                                            Grid.Row="6"
                                            VerticalAlignment="Top" 
                                            Margin="0,32,0,0"
                                            Style="{StaticResource DeBtn}"
                                            Foreground="White"
                                            Click="NextButton_Click"/>
                                </Grid>

                                <Grid x:Name="RegistrationStepTwo" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- 1. Select Department -->
                                    <ComboBox Grid.Row="0" x:Name="DepartmentComboBox" 
                                              Style="{StaticResource StandardComboBox}" 
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Select Department" IsEnabled="False" />
                                    </ComboBox>
                                    <!-- 2. Select Position -->
                                    <ComboBox Grid.Row="1" x:Name="PositionComboBox" 
                                              Style="{StaticResource StandardComboBox}"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Select your Position" IsEnabled="False" />
                                        <ComboBoxItem Content="Manager"/>
                                        <ComboBoxItem Content="Admin"/>
                                        <ComboBoxItem Content="Developer"/>
                                        <ComboBoxItem Content="Designer"/>
                                        <ComboBoxItem Content="Consultant"/>
                                        <ComboBoxItem Content="Intern"/>
                                    </ComboBox>
                                    <!-- 3. Joined Date using a DatePicker -->
                                    <TextBox Grid.Row="2" x:Name="JoinedDatePicker"
                                                Style="{StaticResource WatermarkedTextBox}" Tag="Joined Date"/>
                                    <!-- 4. Email Address -->
                                    <TextBox Grid.Row="3" x:Name="EmailAddressTextBox" 
                                             Style="{StaticResource WatermarkedTextBox}" 
                                             Tag="Email Address"/>
                                    <!-- 5. Password -->
                                    <PasswordBox Grid.Row="4" x:Name="PasswordBox" 
                                                 Style="{StaticResource WatermarkedPasswordBox}"
                                                 local:PasswordBoxHelper.Attach="True"
                                                 local:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Tag="Password" />
                                    <!-- 6. Confirm Password -->
                                    <PasswordBox Grid.Row="5" x:Name="ConfirmPasswordBox" 
                                                 Style="{StaticResource WatermarkedPasswordBox}"
                                                 local:PasswordBoxHelper.Attach="True"
                                                 local:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                                             Tag="Confirm Password"
                                                 Margin="0,0,0,30"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="6">
                                        <Button Content="Back" Style="{StaticResource BackBtn}" Foreground="Black" Click="BackButton_Click" Margin="0,10,35,10"/>
                                        <Button Content="Submit" Style="{StaticResource DeBtn}" Foreground="White" Margin="0,10,-10,10" Click="SubmitButton_Click"/>
                                    </StackPanel>
                                </Grid>

                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>

</Window>